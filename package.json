    "test": "node --test --test-concurrency=1",
    "prepublishOnly": "node scripts/prepublish-gate.mjs && node --test --test-concurrency=1"
  },
  "author": "Sizmo / CJ Salamida",
  "license": "MIT",
  "keywords": [
    "gohighlevel",
    "ghl",
    "crm",
    "cli",
    "leadconnector",
    "confirm-gated"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/csalamida/sizmo-ghl-cli.git"
  },
  "bugs": {
    "url": "https://github.com/csalamida/sizmo-ghl-cli/issues"
  },
  "homepage": "https://github.com/csalamida/sizmo-ghl-cli#readme",
  "files": [
    "bin/",
    "lib/",
    "commands/",
    "SKILL.md",
    "INSTALL.md",
    "SECURITY.md",
    "CHANGELOG.md",
    "API-STABILITY.md",
    "docs/"
  ],
  "publishConfig": {
    "access": "public"
  }
